      <schema_name/>
    </partitioning>
    <connection>atletadata</connection>
    <sql>SELECT 
    j.id_jugador,
    j.nombre,
    j.apellidos,
    j.nombre || ' ' || j.apellidos AS nombre_completo,
    DATE_PART('year', AGE(j.fecha_nacimiento))::INT AS edad,
    j.nacionalidad,
    j.posicion,
    j.dorsal,
    j.peso_kg,
    j.altura_cm,
    j.pie_dominante,
    j.estado,
    c.nombre_club,
    c.liga
FROM oltp_jugadores.jugadores j
JOIN oltp_clubes.clubes c ON j.id_club = c.id_club</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
